<%- include('../layout/header.ejs') %>

    <main class="page-content">
        <div class="container">

            <div class="page-header">
                <h1 class="page-header__title">My Profile</h1>
            </div>

            <div class="page-tools">
                <div class="page-tools__breadcrumbs">
                    <div class="breadcrumbs">
                        <div class="breadcrumbs__container">
                            <ol class="breadcrumbs__list">
                                <li class="breadcrumbs__item">
                                    <a class="breadcrumbs__link" href="/">
                                        <svg class="icon-icon-home breadcrumbs__icon">
                                            <use xlink:href="#icon-home"></use>
                                        </svg>
                                        <svg class="icon-icon-keyboard-right breadcrumbs__arrow">
                                            <use xlink:href="#icon-keyboard-right"></use>
                                        </svg>
                                    </a>
                                </li>
                                <li class="breadcrumbs__item active">
                                    <span class="breadcrumbs__link">My Profile</span>
                                </li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row row--md justify-content-center">
                <div class="col-12 col-lg-6">

                    <form action="/profile/update" method="POST" enctype="multipart/form-data">

                        <div class="col-12 form-group form-group--lg profile-photo-wrapper">
                            <div class="profile-photo-inner">
                                <img id="profilePreview"
                                    src="<%= admin.profile_image ? '/uploads/profile/' + admin.profile_image : '/img/content/humans/item-4.jpg' %>"
                                    alt="Profile Photo" class="profile-photo-img" />
                                <label for="profilePhotoInput" class="profile-photo-label">
                                    <i class="fa-solid fa-camera"></i>
                                </label>
                                <input type="file" id="profilePhotoInput" name="profile_image"
                                    accept="image/jpeg,image/png,.jpg,.jpeg,.png" style="display:none;"
                                    onchange="previewPhoto(this)" />
                            </div>
                            <p class="profile-photo-hint">Click camera icon to change photo</p>
                        </div>

                        <div class="col-12 form-group form-group--lg">
                            <label class="form-label">First Name</label>
                            <div class="input-group">
                                <input class="input" type="text" name="fname" value="<%= admin.fname || '' %>"
                                    placeholder="Enter first name" required />
                            </div>
                        </div>

                        <div class="col-12 form-group form-group--lg">
                            <label class="form-label">Last Name</label>
                            <div class="input-group">
                                <input class="input" type="text" name="lname" value="<%= admin.lname || '' %>"
                                    placeholder="Enter last name" required />
                            </div>
                        </div>

                        <div class="col-12 form-group form-group--lg">
                            <label class="form-label">Email Address</label>
                            <div class="input-group">
                                <input class="input" type="email" name="email" value="<%= admin.email || '' %>"
                                    placeholder="Enter email" required />
                            </div>
                        </div>

                        <div class="col-12 profile-divider">
                            <hr />
                            <p>
                                <i class="fa-solid fa-lock"></i>
                                Change Password
                                <span>(leave blank to keep current)</span>
                            </p>
                        </div>

                        <div class="col-12 form-group form-group--lg">
                            <label class="form-label">New Password</label>
                            <div class="input-group input-group--append">
                                <input class="input" type="password" id="newPassword" name="new_password"
                                    placeholder="Enter new password" minlength="6" />
                                <span class="input-group__append profile-password-toggle"
                                    onclick="togglePass('newPassword')">
                                    <i class="fa-solid fa-eye"></i>
                                </span>
                            </div>
                        </div>

                        <div class="col-12 form-group form-group--lg">
                            <label class="form-label">Confirm Password</label>
                            <div class="input-group input-group--append">
                                <input class="input" type="password" id="confirmPassword" name="confirm_password"
                                    placeholder="Confirm new password" />
                                <span class="input-group__append profile-password-toggle"
                                    onclick="togglePass('confirmPassword')">
                                    <i class="fa-solid fa-eye"></i>
                                </span>
                            </div>
                        </div>

                        <div class="col-12 form-group profile-form-actions">
                            <a href="/" class="button button--secondary">Cancel</a>
                            <button type="submit" class="button button--primary profile-save-btn">
                                <i class="fa-solid fa-floppy-disk"></i> Save Changes
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </main>

    <script>
        function previewPhoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('profilePreview').src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function togglePass(id) {
            const el = document.getElementById(id);
            el.type = el.type === 'password' ? 'text' : 'password';
        }

        document.querySelector('form').addEventListener('submit', function (e) {
            const np = document.getElementById('newPassword').value;
            const cp = document.getElementById('confirmPassword').value;
            if (np && np !== cp) {
                e.preventDefault();
                alert('New password and confirm password do not match.');
            }
        });
    </script>

    <%- include('../layout/footer.ejs') %>