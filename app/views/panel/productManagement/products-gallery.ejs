<%- include('../../layout/header.ejs') %>

    <main class="page-content">
        <div class="container">
            <!-- Combined Header with Add Button -->
            <div class="page-header page-header--with-button">
                <h1 class="page-header__title">Product Gallery</h1>
                <button class="button-add button-add--blue" data-modal="#addGallery">
                    <span class="button-add__icon">
                        <svg class="icon-icon-plus">
                            <use xlink:href="#icon-plus"></use>
                        </svg>
                    </span>
                    <span class="button-add__text"></span>
                </button>
            </div>

            <!-- Breadcrumbs -->
            <div class="page-tools">
                <div class="page-tools__breadcrumbs">
                    <div class="breadcrumbs">
                        <div class="breadcrumbs__container">
                            <ol class="breadcrumbs__list">
                                <li class="breadcrumbs__item">
                                    <a class="breadcrumbs__link" href="/">
                                        <svg class="icon-icon-home breadcrumbs__icon">
                                            <use xlink:href="#icon-home"></use>
                                        </svg>
                                        <svg class="icon-icon-keyboard-right breadcrumbs__arrow">
                                            <use xlink:href="#icon-keyboard-right"></use>
                                        </svg>
                                    </a>
                                </li>
                                <li class="breadcrumbs__item disabled">
                                    <a class="breadcrumbs__link" href="#">
                                        <span>Product Management</span>
                                        <svg class="icon-icon-keyboard-right breadcrumbs__arrow">
                                            <use xlink:href="#icon-keyboard-right"></use>
                                        </svg>
                                    </a>
                                </li>
                                <li class="breadcrumbs__item active">
                                    <span class="breadcrumbs__link">Gallery</span>
                                </li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Messages -->
            <% if (locals.success_msg && success_msg.length> 0) { %>
                <div class="alert alert-success">
                    ✅ <%= success_msg %>
                </div>
                <% } %>
                    <% if (locals.error_msg && error_msg.length> 0) { %>
                        <div class="alert alert-danger">
                            ❌ <%= error_msg %>
                        </div>
                        <% } %>
                            <!-- Add Modal -->
                            <div class="modal modal--panel modal--right" id="addGallery">
                                <div class="modal__overlay" data-dismiss="modal"></div>
                                <div class="modal__wrap">
                                    <div class="modal__window scrollbar-thin" data-simplebar>
                                        <div class="modal__content">
                                            <div class="modal__header">
                                                <div class="modal__container">
                                                    <h2 class="modal__title">Add Gallery</h2>
                                                </div>
                                            </div>
                                            <div class="modal__body">
                                                <div class="modal__container">
                                                    <form id="galleryUploadForm" enctype="multipart/form-data">
                                                        <div class="row row--md">
                                                            <div class="col-12 form-group form-group--lg">
                                                                <label class="form-label">Upload Type</label>
                                                                <select class="input" id="uploadTypeSelect">
                                                                    <option value="">Select upload type</option>
                                                                    <option value="single">Upload Single Image</option>
                                                                    <option value="multiple">Upload Multiple Images
                                                                    </option>
                                                                </select>
                                                            </div>
                                                            <div class="col-12 form-group form-group--lg"
                                                                id="singleInputWrap" style="display:none;">
                                                                <label class="form-label">Select Image</label>
                                                                <input class="input" type="file" id="singleImageInput"
                                                                    accept="image/jpeg,image/png,image/webp,.jpg,.jpeg,.png,.webp" />
                                                            </div>

                                                            <div class="col-12 form-group form-group--lg"
                                                                id="bulkInputWrap" style="display:none;">
                                                                <label class="form-label">Select Images</label>
                                                                <input class="input" type="file" id="bulkImageInput"
                                                                    accept="image/jpeg,image/png,image/webp,.jpg,.jpeg,.png,.webp"
                                                                    multiple />
                                                            </div>

                                                            <div class="col-12 upload-progress" id="uploadProgress"
                                                                style="display:none;">
                                                                <div class="upload-progress__bar-wrap">
                                                                    <div class="upload-progress__bar"
                                                                        id="uploadProgressBar"></div>
                                                                </div>
                                                                <p class="upload-progress__text"
                                                                    id="uploadProgressText"></p>
                                                            </div>
                                                        </div>
                                                </div>
                                            </div>
                                            <div class="modal__footer">
                                                <div class="modal__container">
                                                    <div class="modal__footer-buttons">
                                                        <div class="form-group">
                                                            <button type="button" id="uploadBtn"
                                                                class="button button--primary button--block button--yellow">
                                                                Upload
                                                            </button>
                                                        </div>
                                                        <div class="modal__footer-button">
                                                            <button class="button button--secondary button--block"
                                                                data-dismiss="modal" type="button">
                                                                <span class="button__text">Cancel</span>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Gallery Grid -->
                            <div class="table-wrapper">
                                <div class="gallery-grid">
                                    <% if (locals.gallery && gallery.length> 0) { %>
                                        <% gallery.forEach(function(item) { %>
                                            <div class="gallery-card">
                                                <div class="gallery-card__image-wrap">
                                                    <img src="/uploads/gallery/<%= item.image %>" alt="<%= item.name %>"
                                                        class="gallery-card__image" />
                                                    <% if (item.status !=1) { %>
                                                        <span class="gallery-card__status-badge">Unpublished</span>
                                                        <% } %>
                                                </div>
                                                <div class="gallery-card__actions">
                                                    <button type="button"
                                                        class="gallery-card__action-btn gallery-card__action-btn--edit"
                                                        title="Copy image link"
                                                        onclick="copyLink('/uploads/gallery/<%= item.image %>')">
                                                        <i class="fa-solid fa-link"></i>
                                                    </button>
                                                    <a class="gallery-card__action-btn gallery-card__action-btn--toggle"
                                                        href="/uploads/gallery/<%= item.image %>"
                                                        download="<%= item.image %>" title="Download">
                                                        <i class="fa-solid fa-download"></i>
                                                    </a>
                                                    <form action="/panel/product-gallery/delete" method="POST"
                                                        style="display:inline;"
                                                        onsubmit="return confirm('Delete this post?')">
                                                        <input type="hidden" name="id" value="<%= item.id %>" />
                                                        <button type="submit"
                                                            class="gallery-card__action-btn gallery-card__action-btn--danger"
                                                            title="Delete">
                                                            <i class="fa-solid fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                            <% }) %>
                                                <% } else { %>
                                                    <div class="gallery-grid__empty">
                                                        No gallery posts yet. Click the + button to add one.
                                                    </div>
                                                    <% } %>
                                </div>
                            </div>
        </div>
    </main>

    <!-- Pagination Footer -->
    <div class="table-wrapper__footer">
        <div class="row">
            <div class="table-wrapper__show-result col text-grey">
                <span class="d-none d-sm-inline-block">Showing</span>
                <%= (currentPage - 1) * 12 + 1 %> to <%= Math.min(currentPage * 12, totalItems) %>
                        <span class="d-none d-sm-inline-block">of <%= totalItems %> items</span>
            </div>
            <div class="table-wrapper__pagination col-auto">
                <ol class="pagination">
                    <li class="pagination__item <%= currentPage === 1 ? 'disabled' : '' %>">
                        <a class="pagination__arrow pagination__arrow--prev" href="?page=<%= currentPage - 1 %>">
                            <svg class="icon-icon-keyboard-left">
                                <use xlink:href="#icon-keyboard-left"></use>
                            </svg>
                        </a>
                    </li>
                    <% for(let i=1; i <=totalPages; i++) { %>
                        <li class="pagination__item <%= i === currentPage ? 'active' : '' %>">
                            <a class="pagination__link" href="?page=<%= i %>">
                                <%= i %>
                            </a>
                        </li>
                        <% } %>
                            <li class="pagination__item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                <a class="pagination__arrow pagination__arrow--next"
                                    href="?page=<%= currentPage + 1 %>">
                                    <svg class="icon-icon-keyboard-right">
                                        <use xlink:href="#icon-keyboard-right"></use>
                                    </svg>
                                </a>
                            </li>
                </ol>
            </div>
        </div>
    </div>

    <script>
        function copyLink(path) {
            const fullUrl = window.location.origin + path;
            navigator.clipboard.writeText(fullUrl).then(function () {
                alert('Image link copied!');
            });
        }

        function compressImage(file) {
            return new Promise((resolve) => {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const img = new Image();
                    img.onload = function () {
                        const canvas = document.createElement('canvas');
                        canvas.width = img.width;
                        canvas.height = img.height;
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0);
                        canvas.toBlob((blob) => {
                            resolve(new File([blob], file.name, { type: 'image/jpeg' }));
                        }, 'image/jpeg', 0.8);
                    };
                    img.src = e.target.result;
                };
                reader.readAsDataURL(file);
            });
        }

        function uploadInChunks(file, onProgress) {
            return new Promise(async (resolve, reject) => {
                const CHUNK_SIZE = 1 * 1024 * 1024;
                const totalChunks = Math.ceil(file.size / CHUNK_SIZE);
                const fileId = Date.now() + '_' + Math.random().toString(36).slice(2);

                for (let i = 0; i < totalChunks; i++) {
                    const start = i * CHUNK_SIZE;
                    const end = Math.min(start + CHUNK_SIZE, file.size);
                    const chunk = file.slice(start, end);

                    const formData = new FormData();
                    formData.append('chunk', chunk);
                    formData.append('fileId', fileId);
                    formData.append('chunkIndex', i);
                    formData.append('totalChunks', totalChunks);
                    formData.append('filename', file.name);

                    try {
                        const res = await fetch('/panel/product-gallery/upload-chunk', {
                            method: 'POST',
                            body: formData
                        });
                        if (!res.ok) return reject(new Error(`Chunk ${i + 1} failed`));
                        if (onProgress) onProgress(i + 1, totalChunks);
                    } catch (err) {
                        return reject(err);
                    }
                }
                resolve();
            });
        }

        document.getElementById('uploadTypeSelect').addEventListener('change', function () {
            const val = this.value;
            document.getElementById('singleInputWrap').style.display = val === 'single' ? 'block' : 'none';
            document.getElementById('bulkInputWrap').style.display = val === 'multiple' ? 'block' : 'none';
        });

        document.getElementById('uploadBtn').addEventListener('click', async function () {
            const singleFile = document.getElementById('singleImageInput').files[0];
            const bulkFiles = document.getElementById('bulkImageInput').files;

            const rawFiles = bulkFiles.length > 0 ? Array.from(bulkFiles) : singleFile ? [singleFile] : null;

            if (!rawFiles) return alert('Please select at least one image.');

            const progressWrap = document.getElementById('uploadProgress');
            const progressBar = document.getElementById('uploadProgressBar');
            const progressText = document.getElementById('uploadProgressText');
            progressWrap.style.display = 'block';

            let success = 0, failed = 0;

            for (let i = 0; i < rawFiles.length; i++) {
                try {
                    progressText.textContent = `Compressing ${i + 1} of ${rawFiles.length}: ${rawFiles[i].name}`;
                    const compressed = await compressImage(rawFiles[i]);

                    await uploadInChunks(compressed, (doneChunks, totalChunks) => {
                        const fileProgress = (i / rawFiles.length) * 100;
                        const chunkProgress = (doneChunks / totalChunks) * (100 / rawFiles.length);
                        progressBar.style.width = Math.round(fileProgress + chunkProgress) + '%';
                        progressText.textContent = `Uploading ${i + 1} of ${rawFiles.length}: ${rawFiles[i].name} — chunk ${doneChunks}/${totalChunks}`;
                    });

                    success++;
                } catch (err) {
                    failed++;
                    console.error(err);
                }
            }

            progressBar.style.width = '100%';
            progressText.textContent = `✅ ${success} uploaded${failed ? `, ❌ ${failed} failed` : ''}`;
            setTimeout(() => window.location.reload(), 1500);
        });
    </script>

    <%- include('../../layout/footer.ejs') %>