<%- include('../../layout/header.ejs') %>
    <main class="page-content">
        <div class="container">
            <div class="page-header">
                <h1 class="page-header__title">Child Categories</h1>
            </div>
            <div class="page-tools">
                <div class="page-tools__breadcrumbs">
                    <div class="breadcrumbs">
                        <div class="breadcrumbs__container">
                            <ol class="breadcrumbs__list">
                                <li class="breadcrumbs__item">
                                    <a class="breadcrumbs__link" href="/">
                                        <svg class="icon-icon-home breadcrumbs__icon">
                                            <use xlink:href="#icon-home"></use>
                                        </svg>
                                        <svg class="icon-icon-keyboard-right breadcrumbs__arrow">
                                            <use xlink:href="#icon-keyboard-right"></use>
                                        </svg>
                                    </a>
                                </li>
                                <li class="breadcrumbs__item disabled"><a class="breadcrumbs__link"
                                        href="#"><span>Categories</span>
                                        <svg class="icon-icon-keyboard-right breadcrumbs__arrow">
                                            <use xlink:href="#icon-keyboard-right"></use>
                                        </svg></a>
                                </li>

                                <li class="breadcrumbs__item active"><span class="breadcrumbs__link">Child
                                        Categories</span>
                                </li>
                            </ol>
                        </div>
                    </div>
                </div>
                <div class="page-tools__right">
                </div>
            </div>
            <div class="toolbox">
                <div class="toolbox__row row gutter-bottom-xs">
                    <div class="toolbox__left col-12 col-lg">
                        <div class="toolbox__left-row row row--xs gutter-bottom-xs">
                            <div class="form-group form-group--inline col-12 col-sm-auto">
                                <label class="form-label">Show</label>
                                <div class="input-group input-group--white input-group--append">
                                    <input class="input input--select" type="text" value="10" size="1"
                                        data-toggle="dropdown" readonly><span class="input-group__arrow">
                                        <svg class="icon-icon-keyboard-down">
                                            <use xlink:href="#icon-keyboard-down"></use>
                                        </svg></span>
                                    <div
                                        class="dropdown-menu dropdown-menu--right dropdown-menu--fluid js-dropdown-select">
                                        <a class="dropdown-menu__item active" href="#" tabindex="0"
                                            data-value="10">10</a><a class="dropdown-menu__item" href="#" tabindex="0"
                                            data-value="15">15</a><a class="dropdown-menu__item" href="#" tabindex="0"
                                            data-value="20">20</a>
                                        <a class="dropdown-menu__item" href="#" tabindex="0" data-value="25">25</a><a
                                            class="dropdown-menu__item" href="#" tabindex="0" data-value="50">50</a>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group form-group--inline col col-sm-auto">
                                <div class="input-group input-group--white input-group--append">
                                    <select class="input js-input-select" data-placeholder="">
                                        <option value="1" selected="selected">All Categories
                                        </option>
                                        <option value="2">MacBook
                                        </option>
                                        <option value="3">Apple Watch
                                        </option>
                                        <option value="4">AirPods
                                        </option>
                                        <option value="5">iPhone
                                        </option>
                                        <option value="6">IPad
                                        </option>
                                    </select><span class="input-group__arrow">
                                        <svg class="icon-icon-keyboard-down">
                                            <use xlink:href="#icon-keyboard-down"></use>
                                        </svg></span>
                                </div>
                            </div>
                            <div class="form-group form-group--inline col-12 col-sm-auto d-none d-sm-block">
                                <div class="toolbox__status input-group input-group--white input-group--append">
                                    <input class="input input--select" type="text" value="All status"
                                        data-toggle="dropdown" readonly><span class="input-group__arrow">
                                        <svg class="icon-icon-keyboard-down">
                                            <use xlink:href="#icon-keyboard-down"></use>
                                        </svg></span>
                                    <div
                                        class="dropdown-menu dropdown-menu--right dropdown-menu--fluid js-dropdown-select">
                                        <a class="dropdown-menu__item active" href="#" tabindex="0"
                                            data-value="All status"><span class="marker-item"></span> All status</a>
                                        <a class="dropdown-menu__item" href="#" tabindex="0"
                                            data-value="Published"><span class="marker-item color-green"></span>
                                            Published</a><a class="dropdown-menu__item" href="#" tabindex="0"
                                            data-value="Deleted"><span class="marker-item color-red"></span>
                                            Deleted</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="toolbox__right col-12 col-lg-auto">
                        <div class="toolbox__right-row row row--xs flex-nowrap">
                            <div class="col col-lg-auto">
                                <form class="toolbox__search" method="GET" action="/panel/child-categories">
                                    <div class="input-group input-group--white input-group--prepend">
                                        <div class="input-group__prepend">
                                            <svg class="icon-icon-search">
                                                <use xlink:href="#icon-search"></use>
                                            </svg>
                                        </div>
                                        <input class="input" type="text" name="search" placeholder="Search product"
                                            value="<%= search || '' %>">
                                    </div>
                                </form>
                            </div>
                            <div class="col-auto">
                                <button class="button-add button-add--blue" data-modal="#addProduct"
                                    style="background-color: #EFBF04;"><span class="button-add__icon">
                                        <svg class="icon-icon-plus">
                                            <use xlink:href="#icon-plus"></use>
                                        </svg></span><span class="button-add__text"></span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal modal--panel modal--right" id="addProduct">
                <div class="modal__overlay" data-dismiss="modal"></div>
                <div class="modal__wrap">
                    <div class="modal__window scrollbar-thin" data-simplebar>
                        <div class="modal__content">
                            <div class="modal__header">
                                <div class="modal__container">
                                    <h2 class="modal__title">Add Child Category</h2>
                                </div>
                            </div>
                            <div class="modal__body">
                                <div class="modal__container">
                                    <form action="/panel/add-child-category" method="POST"
                                        enctype="multipart/form-data">
                                        <div class="row row--md">

                                            <!-- Main Category -->
                                            <div class="col-12 form-group form-group--lg">
                                                <label class="form-label">Main Category</label>
                                                <div class="input-group">
                                                    <select class="input" name="category_token" id="addMainCatSelect"
                                                        required>
                                                        <option value="">Select Main Category</option>
                                                        <% categories.forEach((cat)=> { %>
                                                            <option value="<%= cat.category_token %>">
                                                                <%= cat.name %>
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>
                                            </div>

                                            <!-- Sub Category -->
                                            <div class="col-12 form-group form-group--lg">
                                                <label class="form-label">Sub Category</label>
                                                <div class="input-group">
                                                    <select class="input" name="sub_category_token" id="addSubCatSelect"
                                                        required>
                                                        <option value="">Select Sub Category</option>
                                                        <% subcategories.forEach((sub)=> { %>
                                                            <option value="<%= sub.sub_category_token %>"
                                                                data-parent="<%= sub.category_token %>">
                                                                <%= sub.name %>
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>
                                            </div>

                                            <!-- Name -->
                                            <div class="col-12 form-group form-group--lg">
                                                <label class="form-label">Child Category Name</label>
                                                <div class="input-group">
                                                    <input class="input" name="name" type="text"
                                                        placeholder="Enter child category name" required>
                                                </div>
                                            </div>

                                            <!-- Image -->
                                            <div class="col-12 form-group form-group--lg">
                                                <label class="form-label">Category Image</label>
                                                <input class="input" type="file" name="image" accept="image/webp" />
                                            </div>

                                            <!-- Description -->
                                            <div class="col-12 form-group form-group--lg">
                                                <label class="form-label">Description</label>
                                                <textarea name="description" class="input"
                                                    placeholder="Enter Description" rows="4"></textarea>
                                            </div>



                                        </div>
                                </div>
                            </div>
                            <div class="modal__footer">
                                <div class="modal__container">
                                    <div class="modal__footer-buttons">
                                        <div class="form-group">
                                            <button type="submit" class="button button--primary button--block"
                                                style="background-color: #EFBF04;">
                                                Create Category
                                            </button>
                                        </div>
                                        <div class="modal__footer-button">
                                            <button class="button button--secondary button--block" data-dismiss="modal">
                                                <span class="button__text">Cancel</span>
                                            </button>
                                        </div>
                                    </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-wrapper">
                <div class="table-wrapper__content table-products table-collapse scrollbar-thin scrollbar-visible"
                    data-simplebar>
                    <table class="table table--lines">
                        <colgroup>
                            <col class="colgroup-1">
                            <col class="colgroup-2">
                            <col class="colgroup-3">
                            <col>
                            <col>
                            <col>
                            <col>
                            <col>
                        </colgroup>
                        <thead class="table__header">
                            <tr class="table__header-row">
                                <th class="d-none d-lg-table-cell"><span>Sr No.</span>
                                </th>
                                <th class="table__th-sort"><span class="align-middle">Image</span><span
                                        class="sort sort--down"></span>
                                </th>
                                <th class="table__th-sort"><span class="align-middle">Main Category name</span><span
                                        class="sort sort--down"></span>
                                </th>
                                <th class="table__th-sort"><span class="align-middle">Sub Category Name</span><span
                                        class="sort sort--down"></span>
                                </th>
                                <th class="table__th-sort"><span class="align-middle">Child Category name</span><span
                                        class="sort sort--down"></span>
                                </th>
                                <th class="table__th-sort"><span class="align-middle">Status</span><span
                                        class="sort sort--down"></span>
                                </th>
                                <th class="table__th-sort d-none d-lg-table-cell"><span class="align-middle">Created
                                        At</span><span class="sort sort--down"></span>
                                </th>
                                <th class="table__th-sort d-none d-sm-table-cell"><span
                                        class="align-middle">Action</span>
                                </th>
                                <th class="table__actions"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (childCategories && childCategories.length> 0) { %>
                                <% childCategories.forEach((child, index)=> { %>
                                    <tr class="table__row">

                                        <!-- Sr No -->
                                        <td class="d-none d-lg-table-cell table__td">
                                            <%= index + 1 %>
                                        </td>

                                        <!-- Image -->
                                        <td class="table__td">
                                            <% if (child.image) { %>
                                                <img src="/uploads/childcategories/<%= child.image %>"
                                                    alt="child category"
                                                    style="width:50px; height:50px; object-fit:cover; border-radius:6px;">
                                                <% } else { %>
                                                    -
                                                    <% } %>
                                        </td>

                                        <!-- Main Category Name -->
                                        <td class="table__td">
                                            <%= child.main_category_name || '-' %>
                                        </td>

                                        <!-- Sub Category Name -->
                                        <td class="table__td">
                                            <%= child.sub_category_name || '-' %>
                                        </td>

                                        <!-- Child Category Name -->
                                        <td class="table__td">
                                            <%= child.name %>
                                        </td>

                                        <!-- Status -->
                                        <td class="table__td">
                                            <% if (child.status==1) { %>
                                                <span class="text-success">Active</span>
                                                <% } else { %>
                                                    <span class="text-danger">Inactive</span>
                                                    <% } %>
                                        </td>

                                        <!-- Created At -->
                                        <td class="d-none d-lg-table-cell table__td">
                                            <%= new Date(child.created_at).toLocaleDateString() %>
                                        </td>

                                        <!-- Action -->
                                        <td class="d-none d-sm-table-cell table__td">
                                            <div class="card__tools-more">
                                                <button class="items-more__button">
                                                    <i class="fa-solid fa-ellipsis"></i>
                                                </button>
                                                <div class="dropdown-items dropdown-items--left dropdown-items--down">
                                                    <div class="dropdown-items__container">
                                                        <ul class="dropdown-items__list">

                                                            <!-- Edit -->
                                                            <li class="dropdown-items__item">
                                                                <a class="dropdown-items__link" href="#"
                                                                    data-modal="#editProduct"
                                                                    data-child-token="<%= child.child_category_token %>"
                                                                    data-cat-token="<%= child.category_token %>"
                                                                    data-sub-token="<%= child.sub_category_token %>"
                                                                    data-name="<%= child.name %>"
                                                                    data-description="<%= child.description || '' %>"
                                                                    onclick="fillEditForm(this)"
                                                                    style="padding: 0; width: 100%; text-align: left;">
                                                                    <span class="dropdown-items__link-icon">
                                                                        <svg class="icon-icon-task">
                                                                            <use xlink:href="#icon-task"></use>
                                                                        </svg>
                                                                    </span>
                                                                    Edit
                                                                </a>
                                                            </li>

                                                            <!-- Delete -->
                                                            <li class="dropdown-items__item">
                                                                <form action="/panel/delete-child-category"
                                                                    method="POST"
                                                                    onsubmit="return confirm('Are you sure?')"
                                                                    style="margin: 0;">
                                                                    <input type="hidden" name="child_category_token"
                                                                        value="<%= child.child_category_token %>">
                                                                    <button type="submit" class="dropdown-items__link"
                                                                        style="background: none; border: none; padding: 0; width: 100%; text-align: left;">
                                                                        <span class="dropdown-items__link-icon">
                                                                            <svg class="icon-icon-trash">
                                                                                <use xlink:href="#icon-trash"></use>
                                                                            </svg>
                                                                        </span>
                                                                        Delete
                                                                    </button>
                                                                </form>
                                                            </li>

                                                            <!-- Unpublish -->
                                                            <li class="dropdown-items__item">
                                                                <form action="/panel/unpublish-child-category"
                                                                    method="POST" style="margin: 0;">
                                                                    <input type="hidden" name="child_category_token"
                                                                        value="<%= child.child_category_token %>">
                                                                    <button type="submit" class="dropdown-items__link"
                                                                        style="background: none; padding: 0; width: 100%; text-align: left;">
                                                                        <span class="dropdown-items__link-icon">
                                                                            <i class="fa-solid fa-ban"></i>
                                                                        </span>
                                                                        <%= child.status==1 ? 'Unpublish' : 'Publish' %>
                                                                    </button>
                                                                </form>
                                                            </li>

                                                        </ul>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>

                                        <td class="table__actions"></td>

                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="9" class="text-center">No child categories found</td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
                <div class="table-wrapper__footer">
                    <div class="row">
                        <div class="table-wrapper__show-result col text-grey"><span
                                class="d-none d-sm-inline-block">Showing</span> 1 to 10 <span
                                class="d-none d-sm-inline-block">of 50 items</span>
                        </div>
                        <div class="table-wrapper__pagination col-auto">
                            <ol class="pagination">
                                <li class="pagination__item">
                                    <a class="pagination__arrow pagination__arrow--prev" href="#">
                                        <svg class="icon-icon-keyboard-left">
                                            <use xlink:href="#icon-keyboard-left"></use>
                                        </svg>
                                    </a>
                                </li>
                                <li class="pagination__item active"><a class="pagination__link" href="#">1</a>
                                </li>
                                <li class="pagination__item"><a class="pagination__link" href="#">2</a>
                                </li>
                                <li class="pagination__item"><a class="pagination__link" href="#">3</a>
                                </li>
                                <li class="pagination__item pagination__item--dots">...</li>
                                <li class="pagination__item"><a class="pagination__link" href="#">10</a>
                                </li>
                                <li class="pagination__item">
                                    <a class="pagination__arrow pagination__arrow--next" href="#">
                                        <svg class="icon-icon-keyboard-right">
                                            <use xlink:href="#icon-keyboard-right"></use>
                                        </svg>
                                    </a>
                                </li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal modal--panel modal--right" id="editProduct">
            <div class="modal__overlay" data-dismiss="modal"></div>
            <div class="modal__wrap">
                <div class="modal__window scrollbar-thin" data-simplebar>
                    <div class="modal__content">
                        <div class="modal__header">
                            <div class="modal__container">
                                <h2 class="modal__title">Edit Child Category</h2>
                            </div>
                        </div>
                        <div class="modal__body">
                            <div class="modal__container">
                                <form id="editCategoryForm" action="/panel/edit-child-category" method="POST"
                                    enctype="multipart/form-data">
                                    <div class="row row--md">

                                        <!-- Hidden Token -->
                                        <input type="hidden" name="child_category_token" id="edit_child_token">

                                        <!-- Main Category -->
                                        <div class="col-12 form-group form-group--lg">
                                            <label class="form-label">Main Category</label>
                                            <div class="input-group">
                                                <select class="input" name="category_token" id="edit_cat_token"
                                                    required>
                                                    <option value="">Select Main Category</option>
                                                    <% categories.forEach((cat)=> { %>
                                                        <option value="<%= cat.category_token %>">
                                                            <%= cat.name %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                            </div>
                                        </div>

                                        <!-- Sub Category -->
                                        <div class="col-12 form-group form-group--lg">
                                            <label class="form-label">Sub Category</label>
                                            <div class="input-group">
                                                <select class="input" name="sub_category_token" id="edit_sub_token"
                                                    required>
                                                    <option value="">Select Sub Category</option>
                                                    <% subcategories.forEach((sub)=> { %>
                                                        <option value="<%= sub.sub_category_token %>">
                                                            <%= sub.name %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                            </div>
                                        </div>

                                        <!-- Name -->
                                        <div class="col-12 form-group form-group--lg">
                                            <label class="form-label">Child Category Name</label>
                                            <div class="input-group">
                                                <input class="input" name="name" id="edit_name" type="text"
                                                    placeholder="Enter child category name" required>
                                            </div>
                                        </div>


                                        <!-- Image -->
                                        <div class="col-12 form-group form-group--lg">
                                            <label class="form-label">Category Image</label>
                                            <input class="input" type="file" name="image" accept="image/webp" />
                                        </div>

                                        <!-- Description -->
                                        <div class="col-12 form-group form-group--lg">
                                            <label class="form-label">Description</label>
                                            <textarea name="description" id="edit_description" class="input"
                                                placeholder="Enter Description" rows="4"></textarea>
                                        </div>



                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="modal__footer">
                            <div class="modal__container">
                                <div class="modal__footer-buttons">
                                    <div class="form-group">
                                        <button type="submit" form="editCategoryForm"
                                            class="button button--primary button--block"
                                            style="background-color: #EFBF04;">
                                            Update Category
                                        </button>
                                    </div>
                                    <div class="modal__footer-button">
                                        <button class="button button--secondary button--block" data-dismiss="modal">
                                            <span class="button__text">Cancel</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        document.getElementById('addMainCatSelect').addEventListener('change', function () {
            const selectedToken = this.value;
            const subSelect = document.getElementById('addSubCatSelect');
            if (!subSelect.dataset.allOptions) {
                subSelect.dataset.allOptions = subSelect.innerHTML;
            }
            subSelect.innerHTML = subSelect.dataset.allOptions;
            const options = subSelect.querySelectorAll('option');
            options.forEach(opt => {
                if (!opt.value) return;
                if (opt.dataset.parent !== selectedToken) opt.remove();
            });
            if (typeof $ !== 'undefined' && $(subSelect).data('select2')) {
                $(subSelect).trigger('change');
            }
        });

        function fillEditForm(el) {
            document.getElementById('edit_child_token').value = el.dataset.childToken;
            document.getElementById('edit_cat_token').value = el.dataset.catToken;
            document.getElementById('edit_sub_token').value = el.dataset.subToken;
            document.getElementById('edit_name').value = el.dataset.name;
            document.getElementById('edit_description').value = el.dataset.description || '';
        }
    </script>

    <%- include('../../layout/footer.ejs') %>